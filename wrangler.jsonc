{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "docs-rustfs-com",
  "main": "./src/waku.server",
  "compatibility_flags": [
    "nodejs_als",
    "nodejs_compat"
  ],
  "compatibility_date": "2025-11-17",
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist/public",
    "html_handling": "drop-trailing-slash"
  },
  "rules": [
    {
      "type": "ESModule",
      "globs": [
        "**/*.js",
        "**/*.mjs"
      ]
    }
  ],
  "no_bundle": true
}
