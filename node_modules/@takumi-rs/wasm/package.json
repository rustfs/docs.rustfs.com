{
  "name": "@takumi-rs/wasm",
  "version": "2.1.1",
  "description": "WebAssembly bindings for Takumi, a Rust image rendering engine.",
  "keywords": [
    "css",
    "image",
    "jsx",
    "react",
    "rendering",
    "webassembly"
  ],
  "license": "(MIT OR Apache-2.0)",
  "author": {
    "name": "Kane Wang",
    "email": "me@kane.tw",
    "url": "https://kane.tw"
  },
  "repository": {
    "url": "git+https://github.com/kane50613/takumi.git"
  },
  "files": [
    "pkg/takumi_wasm_bg.wasm.d.ts",
    "pkg/takumi_wasm_bg.wasm",
    "dist",
    "bundlers"
  ],
  "type": "module",
  "main": "./dist/export.cjs",
  "module": "./dist/export.mjs",
  "types": "./dist/export.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/export.d.mts",
        "default": "./dist/export.mjs"
      },
      "require": {
        "types": "./dist/export.d.cts",
        "default": "./dist/export.cjs"
      }
    },
    "./no-bundler": {
      "import": {
        "types": "./dist/export.d.mts",
        "default": "./dist/export.mjs"
      },
      "require": {
        "types": "./dist/export.d.cts",
        "default": "./dist/export.cjs"
      }
    },
    "./node": {
      "bun": "./bundlers/bun.mjs",
      "import": {
        "types": "./bundlers/node.d.ts",
        "default": "./bundlers/node.mjs"
      },
      "require": {
        "types": "./bundlers/node.d.cts",
        "default": "./bundlers/node.cjs"
      }
    },
    "./auto": {
      "bun": {
        "types": "./bundlers/bun.d.ts",
        "default": "./bundlers/bun.mjs"
      },
      "workerd": {
        "types": "./bundlers/wasm-module.d.ts",
        "default": "./bundlers/workerd.js"
      },
      "edge-light": {
        "types": "./bundlers/wasm-module.d.ts",
        "default": "./bundlers/next.mjs"
      },
      "unwasm": {
        "types": "./bundlers/wasm-module.d.ts",
        "default": "./bundlers/next.mjs"
      },
      "module": {
        "types": "./bundlers/vite.d.ts",
        "default": "./bundlers/vite.mjs"
      },
      "node": {
        "require": {
          "types": "./bundlers/node.d.cts",
          "default": "./bundlers/node.cjs"
        },
        "default": {
          "types": "./bundlers/node.d.ts",
          "default": "./bundlers/node.mjs"
        }
      },
      "default": {
        "types": "./bundlers/wasm-module.d.ts",
        "default": "./bundlers/vite.mjs"
      }
    },
    "./takumi_wasm_bg.wasm": {
      "types": "./pkg/takumi_wasm_bg.wasm.d.ts",
      "default": "./pkg/takumi_wasm_bg.wasm"
    },
    "./next": {
      "types": "./bundlers/wasm-module.d.ts",
      "default": "./bundlers/next.mjs"
    },
    "./vite": {
      "types": "./bundlers/vite.d.ts",
      "default": "./bundlers/vite.mjs"
    }
  },
  "scripts": {
    "build": "wasm-pack build --no-pack --release --out-dir pkg --target web && bun build:js",
    "build:js": "tsdown",
    "build:debug": "wasm-pack build --no-pack --dev --out-dir pkg --target web && bun build:js",
    "publish-lint": "attw --pack . && publint --strict ."
  },
  "dependencies": {
    "@takumi-rs/helpers": "2.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "csstype": "^3.2.3",
    "tsdown": "^0.22.5",
    "unrun": "^0.3.1"
  },
  "peerDependencies": {
    "csstype": "*"
  },
  "peerDependenciesMeta": {
    "csstype": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  },
  "readme": "README.md"
}
