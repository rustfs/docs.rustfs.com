{
  "name": "@takumi-rs/core",
  "version": "2.1.1",
  "description": "Native Node.js bindings for the Takumi Rust image rendering engine.",
  "keywords": [
    "css",
    "image",
    "jsx",
    "napi",
    "nodejs",
    "og-image",
    "react",
    "rendering"
  ],
  "homepage": "https://takumi.kane.tw/docs/integration",
  "bugs": {
    "url": "https://github.com/kane50613/takumi/issues"
  },
  "license": "(MIT OR Apache-2.0)",
  "author": {
    "name": "Kane Wang",
    "email": "me@kane.tw",
    "url": "https://kane.tw"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kane50613/takumi.git",
    "directory": "takumi-napi"
  },
  "files": [
    "dist",
    "index.d.ts",
    "not-available.js"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/export.cjs",
  "module": "./dist/export.mjs",
  "types": "./dist/export.d.mts",
  "exports": {
    ".": {
      "workerd": {
        "types": "./dist/export.d.mts",
        "default": "./not-available.js"
      },
      "browser": {
        "types": "./dist/export.d.mts",
        "default": "./not-available.js"
      },
      "import": {
        "types": "./dist/export.d.mts",
        "default": "./dist/export.mjs"
      },
      "require": {
        "types": "./dist/export.d.cts",
        "default": "./dist/export.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "napi build --release --no-const-enum --platform --esm --strip",
    "build:js": "tsdown",
    "prepublishOnly": "bun artifacts && napi prepublish -t npm --no-gh-release",
    "artifacts": "napi create-npm-dirs && napi artifacts && napi version",
    "bench": "bun tests/bench/index.tsx",
    "publish-lint": "attw --pack . && publint --strict ."
  },
  "dependencies": {
    "@takumi-rs/helpers": "2.1.1"
  },
  "devDependencies": {
    "@napi-rs/cli": "3.7.2",
    "@types/bun": "^1.3.14",
    "@types/react": "19.2.17",
    "csstype": "^3.2.3",
    "lucide-react": "^1.24.0",
    "mitata": "^1.0.34",
    "react": "^19.2.7",
    "tsdown": "^0.22.5",
    "unrun": "^0.3.1"
  },
  "peerDependencies": {
    "csstype": "*"
  },
  "peerDependenciesMeta": {
    "csstype": {
      "optional": true
    }
  },
  "napi": {
    "binaryName": "core",
    "dtsHeaderFile": "./src/dts-header.d.ts",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl",
      "aarch64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "x86_64-pc-windows-msvc"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "optionalDependencies": {
    "@takumi-rs/core-darwin-x64": "2.1.1",
    "@takumi-rs/core-darwin-arm64": "2.1.1",
    "@takumi-rs/core-linux-arm64-gnu": "2.1.1",
    "@takumi-rs/core-linux-arm64-musl": "2.1.1",
    "@takumi-rs/core-win32-arm64-msvc": "2.1.1",
    "@takumi-rs/core-linux-x64-gnu": "2.1.1",
    "@takumi-rs/core-linux-x64-musl": "2.1.1",
    "@takumi-rs/core-win32-x64-msvc": "2.1.1"
  }
}