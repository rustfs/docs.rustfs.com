{
  "name": "@takumi-rs/helpers",
  "version": "2.1.1",
  "description": "Utility helpers for converting JSX/HTML to Takumi node trees, loading fonts, and processing emoji.",
  "keywords": [
    "css",
    "emoji",
    "html",
    "image",
    "jsx",
    "react",
    "rendering"
  ],
  "homepage": "https://takumi.kane.tw/docs/architecture#fromjsx-helper",
  "bugs": {
    "url": "https://github.com/kane50613/takumi/issues"
  },
  "license": "(MIT OR Apache-2.0)",
  "author": {
    "name": "Kane Wang",
    "email": "me@kane.tw",
    "url": "https://kane.tw"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kane50613/takumi.git",
    "directory": "takumi-helpers"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./html": {
      "import": {
        "types": "./dist/html.d.mts",
        "default": "./dist/html.mjs"
      },
      "require": {
        "types": "./dist/html.d.cts",
        "default": "./dist/html.cjs"
      }
    },
    "./jsx": {
      "import": {
        "types": "./dist/jsx.d.mts",
        "default": "./dist/jsx.mjs"
      },
      "require": {
        "types": "./dist/jsx.d.cts",
        "default": "./dist/jsx.cjs"
      }
    },
    "./emoji": {
      "import": {
        "types": "./dist/emoji.d.mts",
        "default": "./dist/emoji.mjs"
      },
      "require": {
        "types": "./dist/emoji.d.cts",
        "default": "./dist/emoji.cjs"
      }
    },
    "./renderer": {
      "import": {
        "types": "./dist/renderer.d.mts",
        "default": "./dist/renderer.mjs"
      },
      "require": {
        "types": "./dist/renderer.d.cts",
        "default": "./dist/renderer.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "publish-lint": "attw --pack . && publint --strict ."
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "19.2.17",
    "@types/react-dom": "^19.2.3",
    "lucide-react": "^1.24.0",
    "preact": "^10.28.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsdown": "^0.22.5",
    "ultrahtml": "^1.6.0",
    "unrun": "^0.3.1"
  },
  "peerDependencies": {
    "preact": "^10.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "preact": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  }
}
