{
  "name": "takumi-js",
  "version": "2.1.1",
  "description": "All-in-one Takumi package for Node.js and WebAssembly runtimes.",
  "keywords": [
    "css",
    "image",
    "jsx",
    "next-og",
    "og-image",
    "react",
    "rendering",
    "wasm"
  ],
  "homepage": "https://takumi.kane.tw/docs/",
  "bugs": {
    "url": "https://github.com/kane50613/takumi/issues"
  },
  "license": "(MIT OR Apache-2.0)",
  "author": {
    "name": "Kane Wang",
    "email": "me@kane.tw",
    "url": "https://kane.tw"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kane50613/takumi.git",
    "directory": "takumi-js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "imports": {
    "#backend": {
      "workerd": {
        "import": {
          "types": "./dist/backend/wasm.d.mts",
          "default": "./dist/backend/wasm.mjs"
        },
        "require": {
          "types": "./dist/backend/wasm.d.cts",
          "default": "./dist/backend/wasm.cjs"
        }
      },
      "worker": {
        "import": {
          "types": "./dist/backend/wasm.d.mts",
          "default": "./dist/backend/wasm.mjs"
        },
        "require": {
          "types": "./dist/backend/wasm.d.cts",
          "default": "./dist/backend/wasm.cjs"
        }
      },
      "deno": {
        "import": {
          "types": "./dist/backend/wasm.d.mts",
          "default": "./dist/backend/wasm.mjs"
        },
        "require": {
          "types": "./dist/backend/wasm.d.cts",
          "default": "./dist/backend/wasm.cjs"
        }
      },
      "browser": {
        "import": {
          "types": "./dist/backend/wasm.d.mts",
          "default": "./dist/backend/wasm.mjs"
        },
        "require": {
          "types": "./dist/backend/wasm.d.cts",
          "default": "./dist/backend/wasm.cjs"
        }
      },
      "unwasm": {
        "import": {
          "types": "./dist/backend/wasm.d.mts",
          "default": "./dist/backend/wasm.mjs"
        },
        "require": {
          "types": "./dist/backend/wasm.d.cts",
          "default": "./dist/backend/wasm.cjs"
        }
      },
      "bun": {
        "import": {
          "types": "./dist/backend/node.d.mts",
          "default": "./dist/backend/node.mjs"
        },
        "require": {
          "types": "./dist/backend/node.d.cts",
          "default": "./dist/backend/node.cjs"
        }
      },
      "node": {
        "import": {
          "types": "./dist/backend/node.d.mts",
          "default": "./dist/backend/node.mjs"
        },
        "require": {
          "types": "./dist/backend/node.d.cts",
          "default": "./dist/backend/node.cjs"
        }
      },
      "default": {
        "import": {
          "types": "./dist/backend/wasm.d.mts",
          "default": "./dist/backend/wasm.mjs"
        },
        "require": {
          "types": "./dist/backend/wasm.d.cts",
          "default": "./dist/backend/wasm.cjs"
        }
      }
    }
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./response": {
      "import": {
        "types": "./dist/response.d.mts",
        "default": "./dist/response.mjs"
      },
      "require": {
        "types": "./dist/response.d.cts",
        "default": "./dist/response.cjs"
      }
    },
    "./node": {
      "import": {
        "types": "./dist/node.d.mts",
        "default": "./dist/node.mjs"
      },
      "require": {
        "types": "./dist/node.d.cts",
        "default": "./dist/node.cjs"
      }
    },
    "./wasm": {
      "import": {
        "types": "./dist/wasm.d.mts",
        "default": "./dist/wasm.mjs"
      },
      "require": {
        "types": "./dist/wasm.d.cts",
        "default": "./dist/wasm.cjs"
      }
    },
    "./helpers": {
      "import": {
        "types": "./dist/helpers/index.d.mts",
        "default": "./dist/helpers/index.mjs"
      },
      "require": {
        "types": "./dist/helpers/index.d.cts",
        "default": "./dist/helpers/index.cjs"
      }
    },
    "./helpers/emoji": {
      "import": {
        "types": "./dist/helpers/emoji.d.mts",
        "default": "./dist/helpers/emoji.mjs"
      },
      "require": {
        "types": "./dist/helpers/emoji.d.cts",
        "default": "./dist/helpers/emoji.cjs"
      }
    },
    "./helpers/jsx": {
      "import": {
        "types": "./dist/helpers/jsx.d.mts",
        "default": "./dist/helpers/jsx.mjs"
      },
      "require": {
        "types": "./dist/helpers/jsx.d.cts",
        "default": "./dist/helpers/jsx.cjs"
      }
    },
    "./helpers/html": {
      "import": {
        "types": "./dist/helpers/html.d.mts",
        "default": "./dist/helpers/html.mjs"
      },
      "require": {
        "types": "./dist/helpers/html.d.cts",
        "default": "./dist/helpers/html.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "test": "bun test",
    "test:bundlers": "bun test tests/bundlers.test.ts",
    "publish-lint": "attw --pack . && publint --strict ."
  },
  "dependencies": {
    "@takumi-rs/core": "2.1.1",
    "@takumi-rs/helpers": "2.1.1",
    "@takumi-rs/wasm": "2.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "react": "^19.2.7",
    "tsdown": "^0.22.5",
    "unrun": "^0.3.1"
  },
  "engines": {
    "node": ">=18"
  }
}
