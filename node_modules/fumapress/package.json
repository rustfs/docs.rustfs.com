    "fumadocs-mdx": "^15.0.0",
    "fumadocs-openapi": "^11.0.0",
    "fumadocs-ui": "^16.10.0",
    "hono": "*",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sharp": "^0.34.0",
    "waku": "1.0.0-beta.6"
