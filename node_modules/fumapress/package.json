    "sharp": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "fumadocs-openapi": {
      "optional": true
    },
    "@types/mdx": {
      "optional": true
    },
    "fumadocs-mdx": {
      "optional": true
    },
    "@types/react": {
      "optional": true
    }
  },
  "inlinedDependencies": {
    "@fastify/deepmerge": "3.2.1",
    "http-cache-semantics": "4.2.0"
  },
  "scripts": {
    "dev": "tsdown --watch --clean false",
    "build": "tsdown",
    "types:check": "tsc --noEmit"
  }
