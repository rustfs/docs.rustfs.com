    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "fumadocs-core": "^16.11.1",
    "fumadocs-mdx": "^15.1.0",
